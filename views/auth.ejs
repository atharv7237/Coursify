<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentication</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen flex items-center justify-center p-8">

    <div class="max-w-7xl w-full">

        <!-- Hero Section -->
        <div class="text-center mb-16">

            <h1 class="text-7xl md:text-8xl font-extrabold text-orange-500">
                FLY HIGH.
            </h1>

            <p class="text-2xl text-white font-semibold mt-4">
                One Goal. One Roadmap. One Step At A Time.
            </p>

            <p class="text-zinc-400 mt-5 max-w-2xl mx-auto text-lg">
                Tell us where you want to go and we'll build a personalized
                learning path to get you there.
            </p>

        </div>

        <!-- Login & Register Cards -->
        <div class="grid md:grid-cols-2 gap-8">

            <!-- Login -->

            <div class="bg-zinc-900 p-8 rounded-3xl border border-orange-500/20 shadow-xl">

                <h2 class="text-3xl font-bold text-orange-500 mb-6">
                    Login
                </h2>

                <form action="/api/auth/login" method="POST" class="space-y-4">

                    <input type="email" name="email" placeholder="Email"
                        class="w-full bg-zinc-800 p-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500">

                    <input type="password" name="password" placeholder="Password"
                        class="w-full bg-zinc-800 p-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500">

                    <div class="h-[60px] flex items-center">
                        <a href="#" class="text-sm text-zinc-400 hover:text-orange-500">
                            Forgot Password?
                        </a>
                    </div>

                    <button class="w-full bg-orange-500 hover:bg-orange-600 transition py-3 rounded-xl font-semibold">
                        Login
                    </button>

                </form>

            </div>

            <!-- Register -->

            <div class="bg-zinc-900 p-8 rounded-3xl border border-orange-500/20 shadow-xl">

                <h2 class="text-3xl font-bold text-orange-500 mb-6">
                    Register
                </h2>

                <form action="/auth/register" method="POST" class="space-y-4">

                    <input type="text" name="fullname" placeholder="Full Name"
                        class="w-full bg-zinc-800 p-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500">

                    <input type="email" name="email" placeholder="Email"
                        class="w-full bg-zinc-800 p-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500">

                    <input type="password" name="password" placeholder="Password"
                        class="w-full bg-zinc-800 p-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500">

                    <button class="w-full bg-orange-500 hover:bg-orange-600 transition py-3 rounded-xl font-semibold">
                        Register
                    </button>

                </form>

            </div>

        </div>

    </div>

</body>

</html>